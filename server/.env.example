# cq server environment configuration.
#
# Copy this file to server/.env and edit the values before running the server.
# server/.env is gitignored; this example is the canonical reference.

# Required. Secret used to sign JWTs issued by POST /auth/login.
CQ_JWT_SECRET=change-me-dev-jwt-secret

# Required unless CQ_DISABLE_API_KEY_AUTH=1.
# HMAC pepper combined with every API key plaintext under HMAC-SHA256.
# Rotate only via a coordinated mass-revoke.
CQ_API_KEY_PEPPER=change-me-dev-api-key-pepper

# Optional. Set to "1" to skip API key enforcement on the data plane.
# Intended as a one-release migration window for existing deployments that
# have not yet provisioned keys. Unset or leave empty in normal operation.
# CQ_DISABLE_API_KEY_AUTH=

# Optional. SQLite database path inside the container.
CQ_DB_PATH=/data/cq.db

# Optional. HTTP port the server listens on.
# 8742 matches the frontend dev proxy (server/frontend/vite.config.ts).
# Set to 3000 (or anything else) for deployments.
CQ_PORT=8742
