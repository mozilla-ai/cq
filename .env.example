# cq server environment configuration.
#
# Copy this file to .env and edit the values. Docker Compose reads .env from
# the repo root automatically. .env is gitignored; this example is the
# canonical reference.

# Required. Secret used to sign JWTs issued by POST /auth/login.
CQ_JWT_SECRET=change-me-dev-jwt-secret

# Required. HMAC pepper combined with every API key plaintext under
# HMAC-SHA256. Rotate only via a coordinated mass-revoke.
CQ_API_KEY_PEPPER=change-me-dev-api-key-pepper

# Optional. SQLite database path inside the container.
CQ_DB_PATH=/data/cq.db

# Optional. HTTP port the server listens on.
# Default 3000 matches Docker/compose and the Dockerfile healthcheck.
# Use 8742 with make dev-api to match the frontend dev proxy
# (server/frontend/vite.config.ts).
CQ_PORT=3000
